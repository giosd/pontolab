# Banco de dados PostgreSQL (Neon em produção)
# Local: use uma instância PostgreSQL própria ou um branch da Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Chave de assinatura de sessão. Gere uma forte: openssl rand -base64 32
SESSION_SECRET="troque-essa-chave-em-producao"
