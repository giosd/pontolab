# Banco de dados PostgreSQL (Neon em produção)
# Local: use uma instância PostgreSQL própria ou um branch da Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Chave de assinatura de sessão. Gere uma forte: openssl rand -base64 32
SESSION_SECRET="troque-essa-chave-em-producao"

# Rate limiting de autenticação
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=600

# Logger: debug | info | warn | error
LOG_LEVEL=info

# Opcional: rate limit distribuído via Upstash Redis (REST).
# Se ausente, usa fallback em memória (por instância).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
